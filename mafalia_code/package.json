{
  "name": "mafalia-code",
  "version": "1.0.0",
  "description": "Mafalia Code -- Business Operations CoWork Desktop App",
  "main": "dist-electron/main.js",
  "author": "utachicodes",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && npm run build:electron && electron-builder",
    "build:web": "tsc && vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"electron .\"",
    "package": "tsc && vite build && npm run build:electron && electron-builder --win"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.102.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.400.0",
    "dotenv": "^16.4.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.2",
    "vite": "^6.4.2",
    "vite-plugin-electron": "^0.28.7",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "build": {
    "appId": "com.mafalia.code",
    "productName": "Mafalia Code",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "public/mafalia-logo.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
